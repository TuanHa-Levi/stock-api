import os, ssl, urllib3, time, json, logging, requests
from datetime import datetime

urllib3.disable_warnings()
ssl._create_default_https_context = ssl._create_unverified_context
_orig = requests.Session.request
def _patch(self, method, url, **kw):
    kw['verify'] = False
    return _orig(self, method, url, **kw)
requests.Session.request = _patch

TELEGRAM_TOKEN   = "7539470412:AAFhgl22Sf-gbjgqhfPID3L-Oo5U6SBuu5w"
TELEGRAM_CHAT_ID = "421323460"
CLAUDE_API_KEY   = "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"
STOCK_API_URL    = "http://localhost:5000"

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
log = logging.getLogger(__name__)

def tg_send(chat_id, text):
    requests.post(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
        json={"chat_id": chat_id, "text": text, "parse_mode": "Markdown"}, timeout=30)

def tg_get_updates(offset=None):
    params = {"timeout": 30, "allowed_updates": ["message"]}
    if offset: params["offset"] = offset
    r = requests.get(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates", params=params, timeout=40)
    return r.json().get("result", [])

def get_stock_data(symbol):
    try:
        return requests.get(f"{STOCK_API_URL}/stock/{symbol}", timeout=15).json()
    except Exception as e:
        return {"error": str(e)}

def get_vnindex():
    try:
        return requests.get(f"{STOCK_API_URL}/vnindex", timeout=15).json()
    except Exception as e:
        return {"error": str(e)}

def get_sectors():
    try:
        return requests.get(f"{STOCK_API_URL}/sectors", timeout=90).json()
    except Exception as e:
        return {"error": str(e)}

def ask_claude(prompt):
    try:
        r = requests.post("https://api.anthropic.com/v1/messages",
            headers={"x-api-key": CLAUDE_API_KEY, "anthropic-version": "2023-06-01", "content-type": "application/json"},
            json={"model": "claude-sonnet-4-20250514", "max_tokens": 1000,
                  "messages": [{"role": "user", "content": prompt}]}, timeout=60)
        return r.json()["content"][0]["text"]
    except Exception as e:
        return f"Lỗi Claude API: {e}"

def format_stock(d):
    if "error" in d: return f"❌ Lỗi: {d['error']}"
    trend = "📈" if d.get("trend") == "TANG" else "📉"
    rsi = d.get("rsi_14", 0)
    rsi_icon = "🔴" if rsi > 70 else ("🟢" if rsi < 30 else "🟡")
    return (f"{trend} *{d['symbol']}* — {d.get('date','')}\n"
            f"━━━━━━━━━━━━━━\n"
            f"💰 Giá: *{d['close']:,.0f}*\n"
            f"🔼 Cao: {d.get('high',0):,.0f}  🔽 Thấp: {d.get('low',0):,.0f}\n"
            f"📊 KL: {d.get('volume',0):,.0f}\n"
            f"📉 Thay đổi: *{d.get('change',0):+,.2f}* ({d.get('change_pct',0):+.2f}%)\n"
            f"{rsi_icon} RSI(14): {rsi} — {d.get('rsi_signal','')}\n"
            f"📈 MA10: {d.get('ma10',0):,.2f} | MA20: {d.get('ma20',0):,.2f}")

def format_vnindex(d):
    if "error" in d: return f"❌ Lỗi: {d['error']}"
    trend = "📈" if d.get("trend") == "TANG" else "📉"
    return (f"{trend} *VNINDEX* — {d.get('date','')}\n"
            f"━━━━━━━━━━━━━━\n"
            f"📊 Điểm: *{d['close']:,.2f}*\n"
            f"🔼 Cao: {d.get('high',0):,.2f}  🔽 Thấp: {d.get('low',0):,.2f}\n"
            f"📉 Thay đổi: *{d.get('change',0):+.2f}* ({d.get('change_pct',0):+.2f}%)\n"
            f"📦 Nguồn: {d.get('source','')}")

def handle_message(chat_id, text):
    text = text.strip()
    log.info(f"[{chat_id}] → {text}")

    if text in ["/start", "/help"]:
        tg_send(chat_id,
            "🤖 *Stock Bot — Hướng dẫn*\n"
            "━━━━━━━━━━━━━━\n"
            "📊 Giá cổ phiếu: `PVT` hoặc `/stock PVT`\n"
            "📈 VN-Index: `/vnindex`\n"
            "🏭 Dòng tiền ngành: `/sectors`\n"
            "🤖 Phân tích AI: `/phan tich PVT`\n"
            "💡 Khuyến nghị: `/khuyen nghi`\n"
            "💬 Chat tự do với AI!")
        return

    if text.lower() in ["/vnindex", "vnindex"]:
        tg_send(chat_id, "⏳ Đang lấy VN-Index...")
        tg_send(chat_id, format_vnindex(get_vnindex()))
        return

    if text.lower() in ["/sectors", "/dongvon"]:
        tg_send(chat_id, "⏳ Đang phân tích dòng tiền (60s)...")
        d = get_sectors()
        if "error" in d:
            tg_send(chat_id, f"❌ {d['error']}"); return
        msg = f"🏭 *Dòng tiền ngành* — {d.get('updated_at','')}\n━━━━━━━━━━━━━━\n"
        for s in d.get("sectors", []):
            icon = "🟢" if s['avg_change_pct'] > 0.5 else ("🔴" if s['avg_change_pct'] < -0.5 else "⚪")
            msg += f"{icon} {s['sector']}: {s['avg_change_pct']:+.2f}% — {s['signal']}\n"
        tg_send(chat_id, msg)
        return

    parts = text.upper().split()
    symbol = None
    if parts[0] == "/STOCK" and len(parts) > 1:
        symbol = parts[1]
    elif len(parts) == 1 and 2 <= len(parts[0]) <= 5 and parts[0].isalpha():
        symbol = parts[0]

    if symbol:
        tg_send(chat_id, f"⏳ Đang lấy {symbol}...")
        tg_send(chat_id, format_stock(get_stock_data(symbol)))
        return

    if "phan tich" in text.lower():
        sym = text.upper().split()[-1]
        if sym.isalpha():
            tg_send(chat_id, f"🤖 Đang phân tích {sym}...")
            d = get_stock_data(sym)
            vnidx = get_vnindex()
            prompt = (f"Bạn là chuyên gia phân tích chứng khoán Việt Nam.\n"
                     f"VN-Index: {vnidx.get('close','N/A')} điểm ({vnidx.get('change_pct','N/A')}%)\n"
                     f"Dữ liệu {sym}: {json.dumps(d, ensure_ascii=False)}\n\n"
                     f"Phân tích ngắn gọn (5-7 dòng):\n"
                     f"1. Xu hướng giá\n2. Tín hiệu RSI & MA\n3. Khuyến nghị Mua/Bán/Giữ")
            tg_send(chat_id, f"🤖 *Phân tích AI — {sym}*\n━━━━━━━━━━━━━━\n{ask_claude(prompt)}")
        return

    if "khuyen nghi" in text.lower() or "khuyến nghị" in text.lower():
        tg_send(chat_id, "🤖 Đang phân tích thị trường...")
        vnidx = get_vnindex()
        prompt = (f"Chuyên gia đầu tư chứng khoán Việt Nam.\n"
                 f"VN-Index: {vnidx.get('close','N/A')} điểm, {vnidx.get('change_pct','N/A')}%\n"
                 f"Ngày: {datetime.now().strftime('%d/%m/%Y')}\n\n"
                 f"Đưa ra 3 khuyến nghị đầu tư ngắn hạn: tên CP, lý do, vùng giá tham khảo.")
        tg_send(chat_id, f"💡 *Khuyến nghị AI*\n━━━━━━━━━━━━━━\n{ask_claude(prompt)}")
        return

    # Chat tự do
    tg_send(chat_id, "🤖 Đang xử lý...")
    reply = ask_claude(f"Trợ lý đầu tư chứng khoán Việt Nam. Người dùng hỏi: {text}\nTrả lời ngắn gọn tiếng Việt.")
    tg_send(chat_id, reply)

def main():
    log.info("🤖 Stock Bot starting...")
    tg_send(TELEGRAM_CHAT_ID, "✅ *Stock Bot đã khởi động!*\nGõ /help để xem hướng dẫn.")
    offset = None
    while True:
        try:
            updates = tg_get_updates(offset)
            for update in updates:
                offset = update["update_id"] + 1
                msg = update.get("message", {})
                chat_id = str(msg.get("chat", {}).get("id", ""))
                text = msg.get("text", "")
                if chat_id and text:
                    handle_message(chat_id, text)
        except Exception as e:
            log.error(f"Loop error: {e}")
            time.sleep(5)
        time.sleep(1)

if __name__ == "__main__":
    main()
